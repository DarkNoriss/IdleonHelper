{
  "name": "idleon-helper",
  "version": "0.0.0",
  "description": "IdleonHelper is a automated helper for the game Idleon",
  "main": "./out/main/index.js",
  "packageManager": "pnpm@10.11.0",
  "author": "MyAngelCamellia",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "pnpm typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:backend": "powershell -ExecutionPolicy Bypass -File .\\scripts\\build-backend.ps1",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "check": "ultracite check && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "fix": "ultracite fix && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "electron-updater": "^6.6.2",
    "firebase": "^12.12.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^22.19.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "husky": "^9.1.7",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "ultracite": "7.4.0",
    "vite": "^7.3.0",
    "vitest": "^4.1.6",
    "zustand": "^5.0.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      [
        "@semantic-release/release-notes-generator",
        {
          "preset": "conventionalcommits"
        }
      ],
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      "@semantic-release/github"
    ]
  }
}
